# =============================================================
# Secrets only. Copy this file to .env and fill in real values.
# .env is gitignored -- never commit real credentials.
#
# Everything that ISN'T a secret (hosts, ports, database/collection
# names, paths, retry/batch params) lives in config.yaml instead --
# see config.example.yaml.
# =============================================================

EODHD_API_TOKEN=YOUR_EODHD_API_TOKEN_HERE
POSTGRES_USER=YOUR_POSTGRES_USER_HERE
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
