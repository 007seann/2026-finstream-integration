# =============================================================
# Heterogeneous Realtime Financial Data Platform - Environment
# Copy this to .env and fill in your values
# =============================================================

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# --- PostgreSQL ---
POSTGRES_USER=finplatform
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=financial_data
POSTGRES_PORT=5432
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://finplatform:CHANGE_ME@postgres:5432/airflow_metadata

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=finplatform
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=financial_db

# --- EODHD API ---
EODHD_API_TOKEN=your_eodhd_token_here

# --- SEC EDGAR ---
SEC_USER_AGENT=Your Name your_email@example.com

# --- API Ninjas (optional) ---
# NINJA_API_KEY=your_key_here
